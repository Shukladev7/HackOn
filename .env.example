# =============================================================================
# RTO Reallocation Engine - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# --- Server ---
PORT=3000
NODE_ENV=development
ML_SERVICE_URL=http://localhost:8000

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/rto-reallocation
REDIS_URL=redis://localhost:6379

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# --- Root Cause Classifier (Requirement 3.2) ---
CONFIDENCE_THRESHOLD=0.6
SUB_CAUSE_CONFIDENCE_THRESHOLD=0.5

# --- Sale Recovery Predictor (Requirement 4.1) ---
RECOVERY_PROBABILITY_THRESHOLD=0.3
COURIER_REDELIVERY_RECOVERY_THRESHOLD=0.5

# --- Demand Matching (Requirement 5.1) ---
SEARCH_RADIUS_KM=50
CART_RECENCY_DAYS=7
INTENT_THRESHOLD=0.6
REFUSAL_LOOKBACK_DAYS=90

# --- Buyer Ranking (Requirements 6.2, 6.4) ---
RANKING_WEIGHT_DISTANCE=0.25
RANKING_WEIGHT_CONVERSION=0.35
RANKING_WEIGHT_SPEED=0.20
RANKING_WEIGHT_MARGIN=0.20
MIN_BUYER_SCORE=0.4
MAX_RANKED_BUYERS=10

# --- Fraud Detection (Requirement 12.6) ---
FRAUD_RTO_COUNT_THRESHOLD=5
FRAUD_TIME_WINDOW_DAYS=30

# --- Courier Escalation (Requirement 9.2) ---
COURIER_ESCALATION_WINDOW_DAYS=7
COURIER_ESCALATION_THRESHOLD=3

# --- Event Buffering (Requirement 11.3) ---
EVENT_BUFFER_CAPACITY=500000

# --- Retry Policy (Requirement 11.4) ---
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY_MS=1000

# --- Evidence Collection (Requirement 2.1, 2.2) ---
EVIDENCE_SOURCE_TIMEOUT_MS=5000
MIN_EVIDENCE_SOURCES=3
EVIDENCE_LOOKBACK_HOURS=72

# --- Data Retention ---
EVIDENCE_RETENTION_DAYS=90
EVENT_RETENTION_DAYS=365
AUDIT_RETENTION_YEARS=7
